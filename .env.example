# Server Configuration
PORT=3000
HOST=0.0.0.0

# Storage Configuration
# Supported: mongodb, dynamodb, etcd, git
STORAGE_TYPE=mongodb

# MongoDB Configuration (when STORAGE_TYPE=mongodb)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=cqrcfg

# DynamoDB Configuration (when STORAGE_TYPE=dynamodb)
# DYNAMODB_TABLE=cqrcfg
# AWS_REGION=us-east-1
# DYNAMODB_ENDPOINT=http://localhost:8000  # For local development

# etcd Configuration (when STORAGE_TYPE=etcd)
# ETCD_HOSTS=http://localhost:2379,http://localhost:2380
# ETCD_PREFIX=/cqrcfg

# Git Configuration (when STORAGE_TYPE=git)
# GIT_REMOTE_URL=git@github.com:org/config-repo.git  # Optional; if empty, local-only (no pull/push)
# GIT_LOCAL_PATH=/tmp/cqrcfg-git
# GIT_BRANCH=main
# GIT_COMMIT_AUTHOR=cqrcfg <cqrcfg@localhost>
# GIT_PULL_INTERVAL=30000  # Pull interval in ms (default: 30s)
# GIT_USER_NAME=cqrcfg  # Git user.name for commits
# GIT_USER_EMAIL=cqrcfg@localhost  # Git user.email for commits
# GIT_COMMIT_NAME_CLAIM=username
# GIT_COMMIT_EMAIL_CLAIM=useremail
# GIT_ENCRYPTION_SALT=  # Hex-encoded 8-byte salt for encryption (e.g., a1b2c3d4e5f60718)
# GIT_ENCRYPTION_PASSWORD=  # Password for encryption; if both salt and password are set, files are encrypted

# Notifications Configuration (pub/sub)
# Supported: websocket, kafka, amqp
NOTIFICATIONS_TYPE=websocket

# Kafka Configuration (when NOTIFICATIONS_TYPE=kafka)
# KAFKA_BROKERS=localhost:9092,localhost:9093
# KAFKA_TOPIC=cqrcfg-changes
# KAFKA_CLIENT_ID=cqrcfg
# KAFKA_GROUP_ID=cqrcfg-group

# AMQP/RabbitMQ Configuration (when NOTIFICATIONS_TYPE=amqp)
# AMQP_URL=amqp://localhost
# AMQP_EXCHANGE=cqrcfg
# AMQP_EXCHANGE_TYPE=topic

# OIDC Configuration
# At least one of OIDC_JWKS_URIS or OIDC_ISSUERS is required
# Direct JWKS endpoint URLs (comma-separated for multiple)
OIDC_JWKS_URIS=https://your-identity-provider.com/.well-known/jwks.json
# OIDC issuer URLs (comma-separated) - JWKS fetched from .well-known/openid-configuration
# OIDC_ISSUERS=https://accounts.google.com,https://login.microsoftonline.com/common
# Expected audience claim in JWT (optional)
OIDC_AUDIENCE=
# Optional: Comma-separated list of header names containing user claims
# Headers are processed in order, with later headers taking precedence (for merging claims)
# If set, claims (including authz_rules) are read from these headers instead of the access token
# Each header value can be JSON, base64-encoded JSON, or a signed JWT (auto-detected)
# JWT headers are verified using the JWKS before extracting claims
# Example: X-Userinfo,X-Id-Token
# OIDC_CLAIMS_HEADERS=X-Userinfo
# JWKS cache TTL in seconds (default: 120, set to 0 to disable caching)
# OIDC_JWKS_CACHE_TTL=120
# JWT claim name for ACL - can be array, JSON string, or URL (default: authz_rules)
# OIDC_ACL_CLAIM=authz_rules
# Cache TTL for ACL fetched from URLs in seconds (default: 300 = 5 minutes)
# OIDC_ACL_CACHE_TTL=300

# Cache Configuration
# Enable/disable config value caching (default: true)
# CACHE_ENABLED=true
# Maximum number of cache entries (default: 1000)
# CACHE_MAX_SIZE=1000
# Maximum cache memory in bytes (default: 52428800 = 50MB)
# CACHE_MAX_MEMORY=52428800
# Cache TTL in seconds (default: 120 = 2 minutes)
# CACHE_TTL=120

# Logging
LOG_LEVEL=info
