{
  "name": "cqrcfg",
  "version": "1.0.0",
  "description": "Runtime hierarchical configuration service with OIDC-based subtree access control",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "oidc": "npm --prefix mock-oidc start",
    "ui": "npm --prefix ui run dev",
    "ui:build": "npm --prefix ui run build",
    "ui:install": "npm --prefix ui install",
    "test": "node --test test/**/*.test.js",
    "test:docker:up": "docker compose -f docker-compose.test.yml up -d",
    "test:docker:down": "docker compose -f docker-compose.test.yml down -v",
    "test:integration": "npm run test:docker:up && npm run test:wait && npm test; npm run test:docker:down",
    "test:wait": "node test/wait-for-services.js"
  },
  "keywords": [
    "config",
    "configuration",
    "runtime",
    "hierarchical",
    "oidc",
    "jwt",
    "mongodb",
    "dynamodb",
    "etcd",
    "kafka",
    "amqp",
    "pubsub"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/websocket": "^11.0.0",
    "jose": "^5.2.0",
    "dotenv": "^16.3.1",
    "lru-cache": "^10.2.0"
  },
  "optionalDependencies": {
    "mongodb": "^6.3.0",
    "@aws-sdk/client-dynamodb": "~3.540.0",
    "@aws-sdk/lib-dynamodb": "~3.540.0",
    "etcd3": "^1.1.2",
    "kafkajs": "^2.2.4",
    "amqplib": "^0.10.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
